# GCP VS Code — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env && source .env

# Required: Your Google Cloud Project ID
# Find it at: https://console.cloud.google.com/
GCP_PROJECT_ID=

# Optional: Default zone (where VMs are created)
# Pick one close to you: https://cloud.google.com/compute/docs/regions-zones
GCP_ZONE=us-central1-a

# Optional: Default machine type
# Options: e2-standard-2, e2-standard-4, e2-standard-8, e2-standard-16
# Pricing: https://cloud.google.com/compute/vm-instance-pricing
GCP_MACHINE_TYPE=e2-standard-4

# Optional: Boot disk size in GB
GCP_DISK_SIZE=50
